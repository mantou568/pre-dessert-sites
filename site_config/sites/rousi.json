{
  "id": "rousi",
  "name": "Rousi",
  "domain": "https://rousi.pro",
  "encoding": "UTF-8",
  "schema": "NexusPHP",
  "reuse_schema": "NexusPHP",
  "required": {
    "cookie": false,
    "sign_in": true
  },
  "meta": {
    "has_free": true
  },
  "public": false,
  "category": {
    "movie": [
      {
        "id": "movie",
        "cat": "Movies",
        "desc": "电影"
      }
    ],
    "tv": [
      {
        "id": "tv",
        "cat": "TV",
        "desc": "电视剧"
      },
      {
        "id": "animation",
        "cat": "TV",
        "desc": "动画"
      },
      {
        "id": "variety",
        "cat": "Variety",
        "desc": "综艺"
      }
    ]
  },
  "requests": {
    "get_subtitle_url": {
      "disabled": true
    },
    "search": {
      "parser": "JsonPath",
      "method": "GET",
      "path": "/api/torrent/list",
      "params": {
        "page": ["0"],
        "page_size": ["100"],
        "sort": ["created_at DESC"],
        "query": ["{keywords}"],
        "category": ["{category}"]
      },
      "list": {
        "selector": "data.torrents"
      },
      "fields": {
        "id": {
          "selector": "id"
        },
        "category": {
          "selector": "type"
        },
        "title": {
          "selector": "title"
        },
        "details": {
          "selector": "id",
          "filters": [
            {
              "name": "append_left",
              "args": "/torrent/"
            }
          ]
        },
        "download": {
          "selector": "info_hash",
          "filters": [
            {
              "name": "append_left",
              "args": "/download/"
            },
            {
              "name": "append_right",
              "args": "/{passkey}"
            }
          ]
        },
        "size": {
          "selector": "size"
        },
        "grabs": {
          "selector": "downloads"
        },
        "seeders": {
          "selector": "seeders"
        },
        "leechers": {
          "selector": "leechers"
        },
        "date_added": {
          "selector": "created_at",
          "filters": [
            {
              "name": "timestamp",
              "args": [
                "2006-01-02T15:04:05.999999-07:00",
                "2006-01-02T15:04:05-07:00",
                "2006-01-02T15:04:05.999Z"
              ]
            }
          ]
        },
        "downloadvolumefactor": {
          "selector": "promotion.down_multiplier"
        },
        "uploadvolumefactor": {
          "selector": "promotion.up_multiplier"
        },
        "description": {
          "selector": "subtitle"
        },
        "imdb_id": {
          "selector": "attributes.imdb_id"
        }
      }
    },
    "user_basic_info": {
      "parser": "JsonPath",
      "method": "GET",
      "path": "/api/me",
      "fields": {
        "id": {
          "selector": "data.stats.username"
        },
        "name": {
          "selector": "data.stats.username"
        },
        "uploaded": {
          "selector": "data.stats.uploaded",
          "filters": [
            {
              "name": "byte_size"
            }
          ]
        },
        "downloaded": {
          "selector": "data.stats.downloaded",
          "filters": [
            {
              "name": "byte_size"
            }
          ]
        },
        "bonus": {
          "selector": "data.stats.karma"
        },
        "seeding_count": {
          "selector": "data.seeding_leeching_data.seeding_count"
        },
        "leeching_count": {
          "selector": "data.seeding_leeching_data.leeching_count"
        }
      }
    },
    "user_details": {
      "parser": "JsonPath",
      "method": "GET",
      "path": "/api/me",
      "disabled_extends": {
        "headers": true,
        "list": true
      },
      "fields": {
        "level": {
          "selector": "data.stats.level"
        },
        "level_id": {
          "selector": "data.stats.level"
        },
        "join_at": {
          "selector": "data.created_at"
        },
        "last_accessed": {
          "selector": "data.last_active_at"
        },
        "seeding_count": {
          "selector": "data.seeding_leeching_data.seeding_count"
        },
        "uploaded_total": {
          "selector": "data.stats.uploaded",
          "filters": [
            {
              "name": "byte_size"
            }
          ]
        },
        "ratio": {
          "selector": "data.stats.ratio"
        }
      }
    },
    "seeding_size": {
      "parser": "JsonPath",
      "method": "GET",
      "path": "/api/me",
      "disabled_extends": {
        "headers": true,
        "list": true
      },
      "fields": {
        "size": {
          "selector": "data.seeding_leeching_data.seeding_size",
          "filters": [
            {
              "name": "byte_size"
            }
          ]
        }
      }
    },
    "seeding_count": {
      "parser": "JsonPath",
      "method": "GET",
      "path": "/api/me",
      "disabled_extends": {
        "headers": true,
        "list": true
      },
      "fields": {
        "count": {
          "selector": "data.seeding_leeching_data.seeding_count"
        }
      }
    },
    "messages": {
      "parser": "JsonPath",
      "method": "GET",
      "path": "/api/messages",
      "params": {
        "page": ["0"],
        "page_size": ["20"]
      },
      "list": {
        "selector": "data.messages"
      },
      "fields": {
        "title": {
          "selector": "title"
        },
        "id": {
          "selector": "id"
        },
        "date": {
          "selector": "created_at"
        },
        "content": {
          "selector": "content"
        }
      }
    },
    "notice": {
      "parser": "JsonPath",
      "method": "GET",
      "path": "/api/announcements/latest",
      "params": {
        "limit": ["3"]
      },
      "list": {
        "selector": "data"
      },
      "fields": {
        "title": {
          "selector": "title"
        },
        "content": {
          "selector": "body"
        },
        "create_time": {
          "selector": "created_at"
        }
      }
    },
    "details": {
      "parser": "JsonPath",
      "method": "GET",
      "path": "/api/torrent/{id}",
      "success_status_codes": [
        200,
        404
      ],
      "fields": {
        "absent": {
          "selector": "code",
          "filters": [
            {
              "name": "eq",
              "args": "404"
            }
          ]
        },
        "free": {
          "selector": "data.promotion.down_multiplier",
          "filters": [
            {
              "name": "eq",
              "args": "0"
            }
          ]
        },
        "peer_count": {
          "selector": "data.leechers"
        }
      }
    },
    "get_security_info": {
      "parser": "JsonPath",
      "method": "GET",
      "path": "/api/me",
      "tags": [
        "user_profile"
      ],
      "fields": {
        "passkey": {
          "selector": "data.passkey"
        }
      }
    },
    "sign_in": {
      "parser": "JsonPath",
      "method": "POST",
      "path": "/api/points/attendance",
      "params": {
        "mode": ["fixed"]
      },
      "fields": {
        "signed_in": {
          "selector": "code",
          "filters": [
            {
              "name": "eq",
              "args": "0"
            }
          ]
        }
      }
    }
  }
}
