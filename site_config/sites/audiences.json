{
  "id": "audiences",
  "name": "观众",
  "domain": "https://audiences.me",
  "public": false,
  "schema": "NexusPHP",
  "required": {
    "cookie": true,
    "sign_in": true
  },
  "meta": {
    "has_free": true,
    "has_2x_free": true
  },
  "category": {
    "movie": [
      {
        "id": 401,
        "cat": "Movies",
        "desc": "电影/Movies"
      },
      {
        "id": 407,
        "cat": "Movies/Sports",
        "desc": "Sports/体育"
      }
    ],
    "tv": [
      {
        "id": 402,
        "cat": "TV",
        "desc": "剧集/TV-Series"
      },
      {
        "id": 403,
        "cat": "TV",
        "desc": "综艺/TV-Show"
      },
      {
        "id": 406,
        "cat": "TV/Documentary",
        "desc": "纪录片/Documentary"
      }
    ]
  },
  "requests": {
    "search": {
      "fields": {
        "description": {
          "selector": ".torrent-subtitle-line .torrent-subtitle-text"
        },
        "labels": {
          "selector": ".torrent-subtitle-line .torrent-subtitle-tags > .tags",
          "array": true
        },
        "hr_days": {
          "selector": "img.hitandrun",
          "attribute": "title",
          "filters": [
            {
              "name": "not_blank",
              "args": [
                "2",
                "0"
              ]
            }
          ]
        }
      }
    },
    "user_basic_info": {
      "fields": {
        "uploaded": {
          "any": [
            {
              "selector": "//*[contains(@class,'site-userbar__compact-metric--uploaded')]/span/text()[normalize-space()]",
              "filters": [
                {
                  "name": "strip"
                },
                {
                  "name": "byte_size"
                }
              ]
            },
            {
              "selector": "*",
              "selection": "html",
              "filters": [
                {
                  "name": "re_search",
                  "args": [
                    "[^总]上[传傳]量?[:：_<>/a-zA-Z-=''\\s#;]+([\\d,.\\s]+(?i)[KMGTPI]*B)",
                    1
                  ]
                },
                {
                  "name": "byte_size"
                }
              ]
            }
          ]
        },
        "downloaded": {
          "any": [
            {
              "selector": "//*[contains(@class,'site-userbar__compact-metric--downloaded')]/span/text()[normalize-space()]",
              "filters": [
                {
                  "name": "strip"
                },
                {
                  "name": "byte_size"
                }
              ]
            },
            {
              "selector": "*",
              "selection": "html",
              "filters": [
                {
                  "name": "re_search",
                  "args": [
                    "[^总子影力]下[载載]量?[:：_<>/a-zA-Z-=''\\s#;]+([\\d,.\\s]+(?i)[KMGTPI]*B)",
                    1
                  ]
                },
                {
                  "name": "byte_size"
                }
              ]
            }
          ]
        },
        "ratio": {
          "any": [
            {
              "selector": "//*[contains(@class,'site-userbar__compact-metric--ratio')]/span/text()[normalize-space()]",
              "filters": [
                {
                  "name": "strip"
                },
                {
                  "name": "replace",
                  "args": [
                    ",",
                    ""
                  ]
                }
              ]
            },
            {
              "selector": "*",
              "selection": "html",
              "filters": [
                {
                  "name": "re_search",
                  "args": [
                    "分享率[:：_<>/a-zA-Z-=\\\"'\\s#;]+([\\d,.\\s]+)",
                    1
                  ]
                }
              ]
            }
          ]
        },
        "bonus": {
          "any": [
            {
              "selector": "//*[@id='info_block']//a[contains(@class,'site-userbar__compact-metric--bonus') and contains(@href,'mybonus')]/span/text()"
            },
            {
              "selector": "//*[@id='info_block']//a[contains(@href,'mybonus') or contains(@href,'bonus.php')]",
              "filters": [
                {
                  "name": "re_search",
                  "args": [
                    "([\\d,.]+)",
                    1
                  ]
                }
              ]
            },
            {
              "selector": "//*[@id='info_block']//a[contains(@href,'mybonus') or contains(@href,'bonus.php')]/following-sibling::text()",
              "trim_chars": true,
              "filters": [
                {
                  "name": "replace",
                  "args": [
                    "] :",
                    ""
                  ]
                },
                {
                  "name": "re_search",
                  "args": [
                    "([\\d,.]+)",
                    1
                  ]
                }
              ]
            }
          ]
        }
      }
    },
    "seeding_statistics": {
      "parser": "CssSelector",
      "headers": {
        "Referer": "https://audiences.me/userdetails.php"
      },
      "disabled_extends": {
        "headers": true,
        "list": true
      },
      "fields": {
        "count": {
          "selector": "table.table.table-bordered tr:has(td:contains(Total)) td:nth-child(2)"
        },
        "size": {
          "selector": "table.table.table-bordered tr:has(td:contains(Total)) td:nth-child(3)",
          "filters": [
            {
              "name": "byte_size"
            }
          ]
        }
      }
    }
  }
}
